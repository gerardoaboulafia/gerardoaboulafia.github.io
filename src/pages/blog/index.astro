---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<BaseLayout title="Blog — Gerardo Aboulafia">
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl font-bold font-serif mb-10">Blog</h1>

    {posts.length === 0 && <p class="text-slate-500">No posts yet.</p>}

    <ul class="space-y-8">
      {posts.map((p) => (
        <li>
          <a href={`/blog/${p.slug}/`} class="group block">
            <h2 class="text-xl font-semibold group-hover:underline">{p.data.title}</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">{p.data.date}</p>
            <p class="text-slate-600 dark:text-slate-300 mt-2">{p.data.summary}</p>
            {p.data.tags?.length ? (
              <div class="mt-2 flex flex-wrap gap-2">
                {p.data.tags.map((t) => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 border border-slate-200 dark:bg-slate-800 dark:text-slate-300 dark:border-slate-700">#{t}</span>
                ))}
              </div>
            ) : null}
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
