---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { entry: p },
  }));
}

const { entry } = Astro.props;
const data = entry?.data ?? { title: "Post", date: "", summary: "", tags: [] };
const Content = entry ? (await entry.render()).Content : null;
---
<BaseLayout title={`${data.title} — Blog`} description={data.summary}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    {entry ? (
      <article class="prose prose-slate md:prose-lg dark:prose-invert max-w-none">
        <h1 class="!mb-2 !font-bold font-serif !text-3xl md:!text-4xl !leading-tight">
          {data.title}
        </h1>

        <p class="!mt-0 text-sm text-slate-500 dark:text-slate-400">
          {data.date}
        </p>

        {data.tags?.length ? (
          <div class="mt-3 flex flex-wrap gap-2 not-prose">
            {data.tags.map((t) => (
              <span class="text-sm px-3 py-1 rounded-full bg-slate-100 text-slate-700 border border-slate-200 dark:bg-slate-800 dark:text-slate-200 dark:border-slate-700">#{t}</span>
            ))}
          </div>
        ) : null}

        {Content && <div class="mt-8"><Content /></div>}
      </article>
    ) : (
      <div class="py-16">
        <h1 class="text-2xl font-bold mb-2">Post not found</h1>
        <p class="text-slate-600">Return to the <a class="underline" href="/blog/">blog</a>.</p>
      </div>
    )}
  </section>
</BaseLayout>
